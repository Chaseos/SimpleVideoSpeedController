{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.7",
  "default_locale": "en",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs"
  ],
  "description": "__MSG_appDescription__",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}